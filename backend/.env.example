PROJECT_NAME=Padmavat
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1
SECRET_KEY=please-change-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14
ALGORITHM=HS256

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=padmavat
POSTGRES_USER=padmavat
POSTGRES_PASSWORD=padmavat

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- AI / LLM provider --------------------------------------------------
# Pick one: openai | groq | ollama | stub (leave blank to fall back to stub)
#   groq   → FREE tier, llama-3.3-70b-versatile, get key at console.groq.com
#   ollama → fully local, no API cost, install from ollama.com
#   openai → paid, gpt-4o-mini default
#   stub   → no network, deterministic placeholder (CI / no-key dev)
LLM_PROVIDER=groq

# Optional model overrides. Leave blank to use the provider default.
LLM_MODEL_CHAT=
LLM_MODEL_EMBED=

# Provider credentials — only the one matching LLM_PROVIDER is used.
OPENAI_API_KEY=sk-replace-me
GROQ_API_KEY=gsk-replace-me
OLLAMA_BASE_URL=http://localhost:11434/v1

# Legacy aliases — keep set so existing code paths don't break.
OPENAI_MODEL_CHAT=gpt-4o-mini
OPENAI_MODEL_EMBED=text-embedding-3-small

BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
RATE_LIMIT_PER_MINUTE=120
PATIENT_PORTAL_URL=http://localhost:5174

# Daily.co (telehealth + transcription). Leave blank in dev unless
# you have a Daily account with a HIPAA plan + BAA.
DAILY_API_KEY=
DAILY_DOMAIN=
DAILY_WEBHOOK_SECRET=

# Provider-portal base URL (used in staff invite + password-reset links).
PROVIDER_PORTAL_URL=http://localhost:5173

# --- SMTP / transactional email ---------------------------------------
# When SMTP_HOST is unset, emails are LOGGED via structlog instead of
# sent — dev / CI work out of the box.
#
# DEV RECIPES (pick one):
#
# 1) Mailpit (fully local — no real email leaves your machine):
#      docker run -d -p 1025:1025 -p 8025:8025 axllent/mailpit
#      then read inbox at http://localhost:8025
#      SMTP_HOST=localhost  SMTP_PORT=1025  SMTP_USE_TLS=false
#      SMTP_USER=  SMTP_PASSWORD=  (leave both blank)
#
# 2) Gmail App Password + Mailinator (send through real SMTP, read on
#    mailinator.com without signing up):
#      a. Enable 2FA on your Gmail
#      b. Generate App Password: https://myaccount.google.com/apppasswords
#      c. Set:
#         SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_USE_TLS=true
#         SMTP_USER=youraccount@gmail.com
#         SMTP_PASSWORD=<16-char app password, no spaces>
#         SMTP_FROM_EMAIL=youraccount@gmail.com
#      d. Set test-patient/test-user emails to <anything>@mailinator.com
#      e. Read inbox at https://www.mailinator.com/v4/public/inboxes.jsp?to=<anything>
#      ⚠ Mailinator inboxes are PUBLIC — never send real PHI there.
#
# 3) Resend (modern dev API, 100/day free, instant signup):
#      SMTP_HOST=smtp.resend.com  SMTP_PORT=587  SMTP_USE_TLS=true
#      SMTP_USER=resend
#      SMTP_PASSWORD=<your Resend API key>
#
# 4) Mailtrap (free virtual inbox, 100/month free, no real delivery):
#      Get inbox-specific creds from https://mailtrap.io
#
# PRODUCTION: AWS SES with BAA, Postmark transactional, SendGrid Pro,
# Mailgun HIPAA — all speak SMTP, so swap host/port/user/password and
# you're done.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=no-reply@padmavat.health
SMTP_FROM_NAME=Padmavat Health
